pkgbase = voxtype-bin-rc
	pkgdesc = Push-to-talk voice-to-text for Linux (pre-built binaries, release candidate channel)
	pkgver = 0.7.3.rc1
	pkgrel = 2
	url = https://voxtype.io
	install = voxtype-bin-rc.install
	arch = x86_64
	license = MIT
	depends = alsa-lib
	depends = curl
	depends = gcc-libs
	depends = glibc
	optdepends = wtype: keyboard simulation for Wayland (recommended, best CJK support)
	optdepends = dotool: keyboard simulation with layout support (KDE/GNOME compatible)
	optdepends = ydotool: keyboard simulation fallback (X11/TTY support)
	optdepends = wl-clipboard: clipboard support
	optdepends = libnotify: desktop notifications
	optdepends = pipewire: audio server (recommended)
	optdepends = pipewire-alsa: ALSA compatibility for PipeWire (required if using PipeWire)
	optdepends = pulseaudio: audio server (alternative to PipeWire)
	optdepends = vulkan-icd-loader: GPU acceleration via Vulkan for Whisper (enable with: voxtype setup gpu --enable)
	optdepends = cuda: GPU acceleration via CUDA 13 for ONNX engines (NVIDIA GPUs, requires driver 580+)
	optdepends = cuda12.6: GPU acceleration via CUDA 12 for ONNX engines (older NVIDIA setups)
	optdepends = rocm-hip-runtime: GPU acceleration via MIGraphX for ONNX engines (AMD GPUs)
	optdepends = ollama: local AI summarization for meeting mode
	optdepends = gtk4-layer-shell: runtime for the GTK4 on-screen mic visualizer (voxtype-osd-gtk4)
	optdepends = quickshell: Quickshell-based on-screen display frontend (opt in via [osd] frontend = "quickshell")
	provides = voxtype
	conflicts = voxtype
	conflicts = voxtype-bin
	backup = etc/voxtype/config.toml
	source = voxtype-voxtype-bin-rc-0.7.3.rc1-avx2::https://github.com/peteonrails/voxtype/releases/download/v0.7.3-rc1/voxtype-0.7.3-rc1-linux-x86_64-avx2
