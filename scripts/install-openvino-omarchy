#!/bin/bash
#
# OpenVINO Installation Script for Omarchy
#
# Installs Intel OpenVINO and OpenVINO GenAI with CPU, GPU, and NPU support on Arch Linux-based systems.
# Tested on: Hurrican/Performance with Arc GPU and NPU
#
# Usage: install-openvino [OPTIONS]
#
# Options:
#   -h, --help          Show this help message
#   -y, --yes           Non-interactive mode (assume yes to all prompts)
#   -v, --venv PATH     Custom virtual environment path (default: ~/openvino-env)
#   --skip-npu          Skip NPU driver installation
#   --skip-gpu          Skip GPU driver installation
#   --uninstall         Remove OpenVINO installation
#   --verify            Only run verification (check existing installation)
#

set -euo pipefail

# ============================================================================
# Configuration
# ============================================================================

SCRIPT_VERSION="1.0.0"
DEFAULT_VENV_PATH="$HOME/openvino-env"
VENV_PATH="$DEFAULT_VENV_PATH"
LOG_FILE="/tmp/openvino-install-$(date +%Y%m%d-%H%M%S).log"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Options
NON_INTERACTIVE=false
SKIP_NPU=false
SKIP_GPU=false
UNINSTALL=false
VERIFY_ONLY=false

# ============================================================================
# Helper Functions
# ============================================================================

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

info() {
    echo -e "${BLUE}[INFO]${NC} $*"
    log "INFO: $*"
}

success() {
    echo -e "${GREEN}[OK]${NC} $*"
    log "SUCCESS: $*"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
    log "WARN: $*"
}

error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
    log "ERROR: $*"
}

fatal() {
    error "$*"
    echo -e "${RED}Installation failed. Check log: $LOG_FILE${NC}" >&2
    exit 1
}

header() {
    echo ""
    echo -e "${BOLD}=== $* ===${NC}"
    echo ""
    log "=== $* ==="
}

confirm() {
    if $NON_INTERACTIVE; then
        return 0
    fi

    local prompt="${1:-Continue?}"
    echo -n -e "${YELLOW}$prompt [y/N]: ${NC}"
    read -r response
    case "$response" in
        [yY][eE][sS]|[yY]) return 0 ;;
        *) return 1 ;;
    esac
}

check_command() {
    command -v "$1" &> /dev/null
}

check_package() {
    pacman -Qi "$1" &> /dev/null
}

# ============================================================================
# Prerequisite Checks
# ============================================================================

check_prerequisites() {
    header "Checking Prerequisites"

    # Check if running on Arch-based system
    if [[ ! -f /etc/arch-release ]] && [[ ! -f /etc/pacman.conf ]]; then
        fatal "This script is designed for Arch Linux-based systems (like Omarchy)"
    fi
    success "Arch Linux-based system detected"

    # Check for sudo access
    if ! sudo -v &> /dev/null; then
        fatal "This script requires sudo access"
    fi
    success "Sudo access confirmed"

    # Check for internet connectivity
    if ! ping -c 1 archlinux.org &> /dev/null; then
        warn "Cannot reach archlinux.org - check internet connectivity"
        if ! confirm "Continue anyway?"; then
            exit 1
        fi
    else
        success "Internet connectivity confirmed"
    fi

    # Check for required commands
    for cmd in python3 git; do
        if ! check_command "$cmd"; then
            fatal "Required command not found: $cmd"
        fi
    done
    success "Required commands available"

    # Check for yay (AUR helper) - needed for NPU driver
    if ! $SKIP_NPU && ! check_command yay; then
        warn "yay (AUR helper) not found - will use manual AUR build"
    fi

    # Check Python version
    local py_version
    py_version=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
    local py_major py_minor
    py_major=$(echo "$py_version" | cut -d. -f1)
    py_minor=$(echo "$py_version" | cut -d. -f2)
    if [[ "$py_major" -lt 3 ]] || { [[ "$py_major" -eq 3 ]] && [[ "$py_minor" -lt 9 ]]; }; then
        fatal "Python 3.9 or later required (found: $py_version)"
    fi
    success "Python $py_version detected"
}

# ============================================================================
# Installation Functions
# ============================================================================

install_base_packages() {
    header "Phase 1: Installing Base Packages"

    local packages=(python-pip)

    if ! $SKIP_GPU; then
        packages+=(intel-compute-runtime level-zero-loader ocl-icd)
    fi

    if ! $SKIP_NPU; then
        packages+=(chrpath onetbb)
    fi

    info "Installing: ${packages[*]}"

    if sudo pacman -S --needed --noconfirm "${packages[@]}" >> "$LOG_FILE" 2>&1; then
        success "Base packages installed"
    else
        fatal "Failed to install base packages"
    fi
}

setup_virtual_environment() {
    header "Phase 2: Setting Up Python Virtual Environment"

    if [[ -d "$VENV_PATH" ]]; then
        warn "Virtual environment already exists at $VENV_PATH"
        if confirm "Remove and recreate?"; then
            rm -rf "$VENV_PATH"
        else
            info "Using existing virtual environment"
            return 0
        fi
    fi

    info "Creating virtual environment at $VENV_PATH"
    if python3 -m venv "$VENV_PATH" >> "$LOG_FILE" 2>&1; then
        success "Virtual environment created"
    else
        fatal "Failed to create virtual environment"
    fi

    # Activate and upgrade pip
    # shellcheck source=/dev/null
    source "$VENV_PATH/bin/activate"

    info "Upgrading pip..."
    if pip install --upgrade pip >> "$LOG_FILE" 2>&1; then
        success "pip upgraded"
    else
        warn "pip upgrade failed (non-fatal)"
    fi
}

install_openvino() {
    header "Phase 3: Installing OpenVINO"

    # Ensure virtual environment is activated
    # shellcheck source=/dev/null
    source "$VENV_PATH/bin/activate"

    # Check if already installed
    if pip show openvino &> /dev/null; then
        local current_version
        current_version=$(pip show openvino | grep Version | cut -d' ' -f2)
        warn "OpenVINO $current_version already installed"
        if ! confirm "Reinstall/upgrade?"; then
            install_openvino_genai
            return 0
        fi
    fi

    info "Installing OpenVINO via pip..."
    if pip install --upgrade openvino >> "$LOG_FILE" 2>&1; then
        local installed_version
        installed_version=$(pip show openvino | grep Version | cut -d' ' -f2)
        success "OpenVINO $installed_version installed"
    else
        fatal "Failed to install OpenVINO"
    fi

    install_openvino_genai
}

install_openvino_genai() {
    # Ensure virtual environment is activated
    # shellcheck source=/dev/null
    source "$VENV_PATH/bin/activate"

    # Check if already installed
    if pip show openvino-genai &> /dev/null; then
        local current_version
        current_version=$(pip show openvino-genai | grep Version | cut -d' ' -f2)
        warn "OpenVINO GenAI $current_version already installed"
        if ! confirm "Reinstall/upgrade?"; then
            return 0
        fi
    fi

    info "Installing OpenVINO GenAI via pip..."
    if pip install --upgrade openvino-genai >> "$LOG_FILE" 2>&1; then
        local installed_version
        installed_version=$(pip show openvino-genai | grep Version | cut -d' ' -f2)
        success "OpenVINO GenAI $installed_version installed"
    else
        fatal "Failed to install OpenVINO GenAI"
    fi
}

install_npu_driver() {
    if $SKIP_NPU; then
        info "Skipping NPU driver installation (--skip-npu)"
        return 0
    fi

    header "Phase 4: Installing Intel NPU Driver"

    # Check if already installed
    if check_package intel-npu-driver-bin; then
        local current_version
        current_version=$(pacman -Qi intel-npu-driver-bin | grep Version | cut -d: -f2 | xargs)
        warn "intel-npu-driver-bin $current_version already installed"
        if ! confirm "Reinstall?"; then
            # Still need to ensure symlinks exist
            setup_npu_symlinks
            return 0
        fi
    fi

    local build_dir="/tmp/intel-npu-driver-build-$$"
    mkdir -p "$build_dir"
    cd "$build_dir"

    info "Cloning AUR package..."
    if git clone https://aur.archlinux.org/intel-npu-driver-bin.git >> "$LOG_FILE" 2>&1; then
        success "AUR package cloned"
    else
        fatal "Failed to clone AUR package"
    fi

    cd intel-npu-driver-bin

    info "Building package (this may take a few minutes)..."
    # makepkg cannot run as root - drop privileges to the invoking user
    local makepkg_cmd="makepkg -sf --noconfirm"
    local build_result
    if [[ "$EUID" -eq 0 ]] && [[ -n "${SUDO_USER:-}" ]]; then
        # Fix ownership so the non-root user can write to the build directory
        chown -R "$SUDO_USER" .
        sudo -u "$SUDO_USER" bash -c "$makepkg_cmd" >> "$LOG_FILE" 2>&1
        build_result=$?
    else
        $makepkg_cmd >> "$LOG_FILE" 2>&1
        build_result=$?
    fi
    if [[ $build_result -eq 0 ]]; then
        success "Package built successfully"
    else
        fatal "Failed to build NPU driver package"
    fi

    info "Installing NPU driver..."
    if sudo pacman -U --noconfirm intel-npu-driver-bin-*.pkg.tar.zst >> "$LOG_FILE" 2>&1; then
        success "NPU driver installed"
    else
        fatal "Failed to install NPU driver"
    fi

    # Cleanup
    cd /
    rm -rf "$build_dir"

    setup_npu_symlinks
}

setup_npu_symlinks() {
    info "Setting up NPU library symlinks..."

    local src_dir="/usr/lib/x86_64-linux-gnu"
    local dst_dir="/usr/lib"

    if [[ ! -d "$src_dir" ]]; then
        warn "NPU library source directory not found: $src_dir"
        return 0
    fi

    local libs=(
        "libze_intel_npu.so"
        "libze_intel_npu.so.1"
        "libnpu_driver_compiler.so"
    )

    # Find versioned library
    local versioned_lib
    versioned_lib=$(find "$src_dir" -name "libze_intel_npu.so.1.*" 2>/dev/null | head -1)
    if [[ -n "$versioned_lib" ]]; then
        libs+=("$(basename "$versioned_lib")")
    fi

    for lib in "${libs[@]}"; do
        if [[ -f "$src_dir/$lib" ]]; then
            sudo ln -sf "$src_dir/$lib" "$dst_dir/" 2>/dev/null || true
            log "Symlink created: $dst_dir/$lib -> $src_dir/$lib"
        fi
    done

    success "NPU library symlinks configured"
}

configure_kernel_module() {
    if $SKIP_NPU; then
        return 0
    fi

    header "Phase 5: Configuring NPU Kernel Module"

    # Load module immediately
    if lsmod | grep -q intel_vpu; then
        success "intel_vpu module already loaded"
    else
        info "Loading intel_vpu kernel module..."
        if sudo modprobe intel_vpu 2>> "$LOG_FILE"; then
            success "intel_vpu module loaded"
        else
            warn "Failed to load intel_vpu module (may require reboot)"
        fi
    fi

    # Make persistent
    local conf_file="/etc/modules-load.d/intel-npu.conf"
    if [[ -f "$conf_file" ]] && grep -q "intel_vpu" "$conf_file"; then
        success "Module persistence already configured"
    else
        info "Configuring module to load at boot..."
        echo "intel_vpu" | sudo tee "$conf_file" > /dev/null
        success "Module persistence configured"
    fi

    # Check for device node
    if [[ -e /dev/accel/accel0 ]]; then
        success "NPU device detected at /dev/accel/accel0"
    else
        warn "NPU device not found - may require reboot"
    fi
}

configure_user_permissions() {
    header "Phase 6: Configuring User Permissions"

    local groups_to_add=()
    local current_groups
    current_groups=$(groups "$USER")

    if ! echo "$current_groups" | grep -qw "render"; then
        groups_to_add+=(render)
    fi

    if ! echo "$current_groups" | grep -qw "video"; then
        groups_to_add+=(video)
    fi

    if [[ ${#groups_to_add[@]} -eq 0 ]]; then
        success "User already in required groups (render, video)"
        return 0
    fi

    info "Adding user to groups: ${groups_to_add[*]}"
    for group in "${groups_to_add[@]}"; do
        if sudo usermod -aG "$group" "$USER" 2>> "$LOG_FILE"; then
            success "Added to $group group"
        else
            warn "Failed to add to $group group"
        fi
    done

    warn "You must logout and login again for group changes to take effect"
}

# ============================================================================
# Verification
# ============================================================================

verify_installation() {
    header "Verifying Installation"

    if [[ ! -d "$VENV_PATH" ]]; then
        error "Virtual environment not found at $VENV_PATH"
        return 1
    fi

    # shellcheck source=/dev/null
    source "$VENV_PATH/bin/activate"

    if ! pip show openvino &> /dev/null; then
        error "OpenVINO not installed in virtual environment"
        return 1
    fi

    if ! pip show openvino-genai &> /dev/null; then
        warn "OpenVINO GenAI not installed in virtual environment"
    fi

    info "Running device detection..."
    echo ""

    # Use sg to run with render group if not already in it
    local run_cmd="source '$VENV_PATH/bin/activate' && python3"
    if ! groups | grep -qw render; then
        run_cmd="sg render -c \"$run_cmd"
        run_cmd="$run_cmd\""
    fi

    python3 << 'PYEOF'
import sys
try:
    from openvino import Core

    core = Core()
    devices = core.available_devices

    print("=" * 50)
    print("OpenVINO Device Detection Results")
    print("=" * 50)

    # Get version
    try:
        version = core.get_versions('CPU')['CPU'].build_number
        print(f"OpenVINO Version: {version}")
    except:
        print("OpenVINO Version: (unable to detect)")

    print()

    if not devices:
        print("WARNING: No devices detected!")
        sys.exit(1)

    device_status = {"CPU": False, "GPU": False, "NPU": False}

    for device in devices:
        try:
            name = core.get_property(device, "FULL_DEVICE_NAME")
        except:
            name = "(name unavailable)"

        print(f"  [OK] {device}: {name}")

        if device.startswith("CPU"):
            device_status["CPU"] = True
        elif device.startswith("GPU"):
            device_status["GPU"] = True
        elif device.startswith("NPU"):
            device_status["NPU"] = True

    print()
    print("=" * 50)
    print("Summary:")
    for dev, found in device_status.items():
        status = "Available" if found else "Not detected"
        symbol = "[OK]" if found else "[--]"
        print(f"  {symbol} {dev}: {status}")
    print("=" * 50)

    # Check for OpenVINO GenAI
    print()
    try:
        import openvino_genai
        genai_version = openvino_genai.__version__ if hasattr(openvino_genai, '__version__') else "(version unknown)"
        print(f"  [OK] OpenVINO GenAI: {genai_version}")
    except ImportError:
        print("  [--] OpenVINO GenAI: Not installed")
    except Exception as e:
        print(f"  [--] OpenVINO GenAI: Error - {e}")

except ImportError as e:
    print(f"ERROR: Failed to import OpenVINO: {e}")
    sys.exit(1)
except Exception as e:
    print(f"ERROR: {e}")
    sys.exit(1)
PYEOF

    local exit_code=$?
    echo ""

    if [[ $exit_code -eq 0 ]]; then
        success "Verification completed"
    else
        error "Verification failed"
    fi

    return $exit_code
}

# ============================================================================
# Uninstallation
# ============================================================================

uninstall() {
    header "Uninstalling OpenVINO"

    if ! confirm "This will remove OpenVINO, OpenVINO GenAI, the virtual environment, and NPU driver. Continue?"; then
        info "Uninstall cancelled"
        exit 0
    fi

    # Remove openvino-genai from venv before removing the venv itself
    if [[ -d "$VENV_PATH" ]]; then
        # shellcheck source=/dev/null
        source "$VENV_PATH/bin/activate"
        if pip show openvino-genai &> /dev/null; then
            info "Removing OpenVINO GenAI..."
            pip uninstall -y openvino-genai >> "$LOG_FILE" 2>&1 && success "OpenVINO GenAI removed" || warn "Failed to remove OpenVINO GenAI"
        fi
        if pip show openvino &> /dev/null; then
            info "Removing OpenVINO..."
            pip uninstall -y openvino >> "$LOG_FILE" 2>&1 && success "OpenVINO removed" || warn "Failed to remove OpenVINO"
        fi
        deactivate 2>/dev/null || true

        info "Removing virtual environment at $VENV_PATH"
        rm -rf "$VENV_PATH"
        success "Virtual environment removed"
    else
        info "Virtual environment not found"
    fi

    # Remove NPU driver
    if check_package intel-npu-driver-bin; then
        info "Removing NPU driver..."
        if sudo pacman -R --noconfirm intel-npu-driver-bin >> "$LOG_FILE" 2>&1; then
            success "NPU driver removed"
        else
            warn "Failed to remove NPU driver"
        fi
    fi

    # Remove symlinks
    info "Removing NPU library symlinks..."
    sudo rm -f /usr/lib/libze_intel_npu.so* /usr/lib/libnpu_driver_compiler.so 2>/dev/null || true

    # Remove module config
    if [[ -f /etc/modules-load.d/intel-npu.conf ]]; then
        sudo rm -f /etc/modules-load.d/intel-npu.conf
        success "Module configuration removed"
    fi

    success "Uninstallation complete"
    info "Note: Base packages (intel-compute-runtime, etc.) were not removed"
}

# ============================================================================
# Usage and Main
# ============================================================================

show_help() {
    cat << EOF
OpenVINO Installation Script for Omarchy v$SCRIPT_VERSION

Usage: $(basename "$0") [OPTIONS]

Options:
  -h, --help          Show this help message
  -y, --yes           Non-interactive mode (assume yes to all prompts)
  -v, --venv PATH     Custom virtual environment path (default: ~/openvino-env)
  --skip-npu          Skip NPU driver installation
  --skip-gpu          Skip GPU driver installation
  --uninstall         Remove OpenVINO installation
  --verify            Only run verification (check existing installation)

Examples:
  $(basename "$0")                    # Interactive installation
  $(basename "$0") -y                 # Non-interactive installation
  $(basename "$0") -v ~/my-venv       # Custom venv path
  $(basename "$0") --verify           # Check existing installation
  $(basename "$0") --uninstall        # Remove installation

After installation:
  source ~/openvino-env/bin/activate
  python3 -c "from openvino import Core; print(Core().available_devices)"

For more information, see:
  /usr/share/doc/omarchy/openvino-installation-guide.md

EOF
}

main() {
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -y|--yes)
                NON_INTERACTIVE=true
                shift
                ;;
            -v|--venv)
                VENV_PATH="$2"
                shift 2
                ;;
            --skip-npu)
                SKIP_NPU=true
                shift
                ;;
            --skip-gpu)
                SKIP_GPU=true
                shift
                ;;
            --uninstall)
                UNINSTALL=true
                shift
                ;;
            --verify)
                VERIFY_ONLY=true
                shift
                ;;
            *)
                error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done

    # Expand ~ in VENV_PATH
    VENV_PATH="${VENV_PATH/#\~/$HOME}"

    echo ""
    echo -e "${BOLD}OpenVINO Installation Script for Omarchy${NC}"
    echo -e "Version: $SCRIPT_VERSION"
    echo -e "Log file: $LOG_FILE"
    echo ""

    log "Script started with options: NON_INTERACTIVE=$NON_INTERACTIVE SKIP_NPU=$SKIP_NPU SKIP_GPU=$SKIP_GPU"
    log "VENV_PATH=$VENV_PATH"

    if $VERIFY_ONLY; then
        verify_installation
        exit $?
    fi

    if $UNINSTALL; then
        uninstall
        exit 0
    fi

    # Show installation summary
    echo "Installation Summary:"
    echo "  - Virtual environment: $VENV_PATH"
    echo "  - GPU support: $( $SKIP_GPU && echo 'Skip' || echo 'Install' )"
    echo "  - NPU support: $( $SKIP_NPU && echo 'Skip' || echo 'Install' )"
    echo ""

    if ! confirm "Proceed with installation?"; then
        info "Installation cancelled"
        exit 0
    fi

    # Run installation phases
    check_prerequisites
    install_base_packages
    setup_virtual_environment
    install_openvino
    install_npu_driver
    configure_kernel_module
    configure_user_permissions

    # Final verification
    echo ""
    if confirm "Run verification now?"; then
        verify_installation
    fi

    header "Installation Complete"

    echo -e "${GREEN}OpenVINO has been successfully installed!${NC}"
    echo ""
    echo "To use OpenVINO:"
    echo "  source $VENV_PATH/bin/activate"
    echo "  python3 -c \"from openvino import Core; print(Core().available_devices)\""
    echo ""

    if ! groups | grep -qw render; then
        echo -e "${YELLOW}IMPORTANT: Logout and login again for device access permissions.${NC}"
        echo ""
    fi

    echo "Log file: $LOG_FILE"
    echo ""
}

# Run main function
main "$@"